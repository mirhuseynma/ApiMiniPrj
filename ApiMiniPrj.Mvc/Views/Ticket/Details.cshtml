@using ApiMiniPrj.Application.DTOs.Tickets
@model GetTicketDto
@{
    ViewData["Title"] = "Ticket details";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Ticket details</h1>
    <div>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Type</dt>
    <dd class="col-sm-9">@Model.Type</dd>

    <dt class="col-sm-3">Event</dt>
    <dd class="col-sm-9">@Model.Event?.Title</dd>

    <dt class="col-sm-3">Quantity</dt>
    <dd class="col-sm-9">@Model.Quantity</dd>

    <dt class="col-sm-3">Price</dt>
    <dd class="col-sm-9">@Model.Price</dd>

    <dt class="col-sm-3">Available</dt>
    <dd class="col-sm-9">@(Model.IsAvaiable ? "Yes" : "No")</dd>
</dl>

@if (Model.Event is not null)
{
    <h2 class="h5 mt-4">Event info</h2>
    <dl class="row">
        <dt class="col-sm-3">Date</dt>
        <dd class="col-sm-9">@Model.Event.Date.ToString("yyyy-MM-dd HH:mm")</dd>

        <dt class="col-sm-3">Location</dt>
        <dd class="col-sm-9">@Model.Event.Location</dd>
    </dl>
}
