@using ApiMiniPrj.Mvc.Models.Organizers
@model OrganizerIndexVM
@{
    ViewData["Title"] = "Organizers";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Organizers</h1>
    <a class="btn btn-primary" asp-action="Create">Create</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

@if (!Model.Organizers.Any())
{
    <div class="alert alert-info" role="alert">
        No organizers found.
    </div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th scope="col">#</th>
                <th scope="col">Logo</th>
                <th scope="col">Full name</th>
                <th scope="col">Email</th>
                <th scope="col">Phone</th>
                <th scope="col" class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var organizer in Model.Organizers)
            {
                <tr>
                    <th scope="row">@organizer.Id</th>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(organizer.LogoUrl))
                        {
                            <img src="@organizer.LogoUrl" alt="@organizer.FullName" class="rounded" style="width:48px;height:48px;object-fit:cover;" />
                        }
                    </td>
                    <td>@organizer.FullName</td>
                    <td>@organizer.Email</td>
                    <td>@organizer.PhoneNumber</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@organizer.Id">Details</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@organizer.Id">Edit</a>
                        <form asp-action="Delete" asp-route-id="@organizer.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this organizer?');">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
