@using ApiMiniPrj.Application.DTOs.Events
@model GetEventDto
@{
    ViewData["Title"] = "Event details";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Event details</h1>
    <div>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.BannerImageUrl))
{
    <img src="@Model.BannerImageUrl" alt="@Model.Title" class="rounded mb-3" style="max-width:360px;max-height:220px;object-fit:cover;" />
}

<dl class="row">
    <dt class="col-sm-3">Title</dt>
    <dd class="col-sm-9">@Model.Title</dd>

    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.Description</dd>

    <dt class="col-sm-3">Date</dt>
    <dd class="col-sm-9">@Model.Date.ToString("yyyy-MM-dd HH:mm")</dd>

    <dt class="col-sm-3">Location</dt>
    <dd class="col-sm-9">@Model.Location</dd>

    <dt class="col-sm-3">Organizer</dt>
    <dd class="col-sm-9">@Model.Organizer?.FullName</dd>
</dl>

@if (Model.Tickets.Any())
{
    <h2 class="h5 mt-4">Tickets</h2>
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Type</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Available</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ticket in Model.Tickets)
            {
                <tr>
                    <td>@ticket.Type</td>
                    <td>@ticket.Price</td>
                    <td>@ticket.Quantity</td>
                    <td>@(ticket.IsAvailable ? "Yes" : "No")</td>
                </tr>
            }
        </tbody>
    </table>
}
