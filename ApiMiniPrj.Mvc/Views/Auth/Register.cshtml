@using ApiMiniPrj.Mvc.Models.Auth
@* create register view *@

@model AuthVM
@{
    ViewData["Title"] = "Register";
    var registerModel = Model.Register;
}

<div class="container mt-5">
    <h2>Register</h2>
    <form asp-action="Register" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="mb-3">
            <label asp-for="Register.FullName" class="form-label"></label>
            <input asp-for="Register.FullName" class="form-control" />
            <span asp-validation-for="Register.FullName" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Register.UserName" class="form-label"></label>
            <input asp-for="Register.UserName" class="form-control" />
            <span asp-validation-for="Register.UserName" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Register.Email" class="form-label"></label>
            <input asp-for="Register.Email" class="form-control" />
            <span asp-validation-for="Register.Email" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Register.Password" class="form-label"></label>
            <input asp-for="Register.Password" class="form-control" type="password" />
            <span asp-validation-for="Register.Password" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Register.RePassword" class="form-label"></label>
            <input asp-for="Register.RePassword" class="form-control" type="password" />
            <span asp-validation-for="Register.RePassword" class="text-danger"></span>
        </div>

        @* check accept terms *@
        <div class="mb-3 form-check">
            <input asp-for="Register.AcceptTerms" class="form-check-input" />
            <label asp-for="Register.AcceptTerms" class="form-check-label">I accept the terms and conditions</label>
            <span asp-validation-for="Register.AcceptTerms" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Register</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
