@using ApiMiniPrj.Mvc.Models.Tickets
@model TicketIndexVM
@{
    ViewData["Title"] = "Tickets";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Tickets</h1>
    <a class="btn btn-primary" asp-action="Create">Create</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

@if (!Model.Tickets.Any())
{
    <div class="alert alert-info" role="alert">
        No tickets found.
    </div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th scope="col">#</th>
                <th scope="col">Type</th>
                <th scope="col">Event</th>
                <th scope="col">Quantity</th>
                <th scope="col">Price</th>
                <th scope="col">Available</th>
                <th scope="col" class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ticket in Model.Tickets)
            {
                <tr>
                    <th scope="row">@ticket.Id</th>
                    <td>@ticket.Type</td>
                    <td>@ticket.Event?.Title</td>
                    <td>@ticket.Quantity</td>
                    <td>@ticket.Price</td>
                    <td>@(ticket.IsAvaiable ? "Yes" : "No")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@ticket.Id">Details</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@ticket.Id">Edit</a>
                        <form asp-action="Delete" asp-route-id="@ticket.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this ticket?');">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
